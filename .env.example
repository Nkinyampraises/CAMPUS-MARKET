# Frontend API base URLs
VITE_API_URL="http://localhost:8002"
VITE_ANDROID_API_URL="http://localhost:8002"
VITE_LOCAL_API_PORT="8002"
VITE_LOCAL_API_URL=""

# Backend catalog seeding
# Keep this false to read only what already exists in Postgres.
AUTO_SEED_CATALOG_DEFAULTS="false"

# WebRTC / TURN (required for reliable mobile call connectivity)
VITE_TURN_URLS=""
VITE_TURN_USERNAME=""
VITE_TURN_CREDENTIAL=""

# Optional: force relay-only candidates for stricter NAT/mobile networks
VITE_WEBRTC_ICE_TRANSPORT_POLICY="relay"

# AI provider setup (`openai`, `gemini`, `huggingface`, or `auto`)
AI_PROVIDER="auto"
HF_AUTOTRAIN_API_BASE=""
HF_AUTOTRAIN_API_KEY=""
AI_CHAT_DAILY_LIMIT="7"
AI_DAILY_LIMIT_TIMEZONE="Africa/Lagos"

# OpenAI (existing)
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4.1-mini"
OPENAI_TRANSCRIBE_MODEL="gpt-4o-mini-transcribe"

# Gemini
GEMINI_API_KEY=""
GEMINI_CHAT_MODEL="gemini-2.0-flash"

# Hugging Face (either of these token variables works)
HUGGING_FACE_API_KEY=""
HF_TOKEN=""
HUGGING_FACE_MODEL="Qwen/Qwen2.5-7B-Instruct"

# Demo marketplace seeding (legacy flag; ignored by current server implementation)
ENABLE_DEMO_MARKETPLACE_SEED="false"

# ── Authentication / security ────────────────────────────────────────────────
# Require new signups to verify their email before they can sign in (default on).
AUTH_REQUIRE_EMAIL_CONFIRMATION="true"
# How new signups verify: "code" (6-digit, default) or "link".
AUTH_EMAIL_VERIFICATION_METHOD="code"
# Force an email-code challenge for every non-admin login. Two-factor is opt-in
# per user by default, so keep this false unless you want mandatory 2FA.
AUTH_REQUIRE_TWO_FACTOR="false"
# Require an emailed code the first time an account signs in from a new device/
# browser. OFF by default so normal login is just email + password.
AUTH_CHALLENGE_NEW_DEVICE="false"
# Encryption key (AES-GCM) for TOTP secrets at rest. Falls back to JWT_SECRET if
# unset, but set a dedicated 32+ char value in production.
TWO_FACTOR_ENC_KEY=""
# How long a "remember this device" trust lasts before a new-device challenge is
# required again (milliseconds; default 30 days).
TRUSTED_DEVICE_TTL_MS="2592000000"
# Signup verification code lifetime (milliseconds; default 15 minutes).
EMAIL_VERIFICATION_CODE_TTL_MS="900000"
# Reveal challenge codes in API responses for local/demo use only — keep OFF in prod.
TWO_FACTOR_DEV_REVEAL="false"
