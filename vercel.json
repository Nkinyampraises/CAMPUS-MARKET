{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/make-server-50b25a4f/(.*)",
      "dest": "/api/make-server-50b25a4f/%5B...path%5D.ts?path=$1"
    },
    {
      "src": "/make-server-50b25a4f/(.*)",
      "dest": "/api/make-server-50b25a4f/%5B...path%5D.ts?path=$1"
    },
    {
      "src": "/api/make-server-50b25a4f",
      "dest": "/api/make-server-50b25a4f/%5B...path%5D.ts"
    },
    {
      "src": "/make-server-50b25a4f",
      "dest": "/api/make-server-50b25a4f/%5B...path%5D.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
