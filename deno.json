{
  "tasks": {
    "start": "deno run --sloppy-imports --node-modules-dir=manual --no-check --allow-net --allow-env --allow-read --env-file=.env server/index.ts",
    "check:server": "deno check --sloppy-imports --node-modules-dir=manual server/index.ts"
  },
  "nodeModulesDir": "manual",
  "exclude": [
    "src/**",
    "dist/**",
    "vite.config.ts",
    "postcss.config.mjs"
  ],
  "deploy": {
    "org": "campusmarket",
    "app": "campus-market-live"
  }
}







































